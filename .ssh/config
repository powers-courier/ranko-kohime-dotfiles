Host copilot
  HostName              copilot.theatomicass.com
  Port                  443

Host asknas
  HostName              192.168.1.22

Host *
  AddressFamily         any
  CheckHostIP           yes
  Compression           yes
  ExitOnForwardFailure  yes
  GatewayPorts          no
  HashKnownHosts        yes
  IdentitiesOnly        yes
  IdentityFile          ~/.ssh/id_ed25519
  ServerAliveInterval   60
  StrictHostKeyChecking ask
  UserKnownHostsFile    ~/.ssh/known_hosts
  VisualHostKey         yes
